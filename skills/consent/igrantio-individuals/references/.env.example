# --- iGrant.io individuals (Consent BB admin) ---
PORT=6003

# OWS environment: demo (default) | staging
OWS_ENV=demo
# Optional explicit override of the base URL.
# OWS_BASE_URL=

# Organisation API key for the Consent BB (server-side only — never in the browser).
OWS_API_KEY=your-org-api-key

# Comma-separated allowed browser origins (if you expose the example endpoints).
CORS_ORIGINS=http://localhost:4321
