# --- iGrant.io issuer backend ---
PORT=6001

# OWS environment: demo (default) | staging. Integrator's choice.
OWS_ENV=demo
# Optional override of the resolved base URL (e.g. an in-cluster service URL).
# Leave unset to use the OWS_ENV mapping (demo -> https://demo-api.igrant.io,
# staging -> https://staging-api.igrant.io).
# OWS_BASE_URL=

# Shared HMAC secret - MUST equal the secretKey used when registering the webhook.
WEBHOOK_SECRET_KEY=change-me-shared-secret

# Public origin of THIS backend (used to build the webhook payloadUrl at registration).
PUBLIC_BASE_URL=https://your-issuer-backend.example.com

# Comma-separated allowed browser origins. Empty = reflect any origin (dev only).
CORS_ORIGINS=http://localhost:4321,https://your-frontend.example.com

# Proxy mount path. Frontend base becomes ${PROXY_PREFIX}/${tenant}, e.g. /ows/acme
PROXY_PREFIX=/ows

EVENT_TTL_MS=600000
UPSTREAM_TIMEOUT_MS=120000

# --- Per-tenant OWS API keys ---
# One per organisation: OWS_TENANT_<SLUG>_API_KEY  (slug upper-cased, non-alphanumerics -> _)
OWS_TENANT_ACME_API_KEY=your-acme-issuer-api-key
